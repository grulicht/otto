# OTTO Environment Variables
# Copy this file to ~/.config/otto/.env and fill in your values.
# NEVER commit the actual .env file!

# --- Communication ---

# Slack Bot Token (xoxb-...)
# OTTO_SLACK_TOKEN=
# OTTO_SLACK_CHANNEL_ID=

# Telegram Bot Token
# OTTO_TELEGRAM_TOKEN=
# OTTO_TELEGRAM_CHAT_ID=

# RocketChat
# OTTO_ROCKETCHAT_URL=
# OTTO_ROCKETCHAT_TOKEN=
# OTTO_ROCKETCHAT_USER_ID=

# MS Teams Webhook URL
# OTTO_TEAMS_WEBHOOK_URL=

# Discord Bot Token
# OTTO_DISCORD_TOKEN=
# OTTO_DISCORD_CHANNEL_ID=

# Email (SMTP)
# OTTO_SMTP_HOST=
# OTTO_SMTP_PORT=587
# OTTO_SMTP_USER=
# OTTO_SMTP_PASS=
# OTTO_EMAIL_FROM=
# OTTO_EMAIL_TO=

# --- Cloud Providers ---

# AWS (or use ~/.aws/credentials)
# AWS_PROFILE=
# AWS_REGION=

# GCP (or use gcloud auth)
# GOOGLE_APPLICATION_CREDENTIALS=

# Azure (or use az login)
# AZURE_SUBSCRIPTION_ID=

# DigitalOcean
# DIGITALOCEAN_TOKEN=

# Hetzner
# HETZNER_TOKEN=

# --- Monitoring ---

# Grafana
# OTTO_GRAFANA_URL=
# OTTO_GRAFANA_TOKEN=

# Zabbix
# OTTO_ZABBIX_URL=
# OTTO_ZABBIX_TOKEN=

# Datadog
# OTTO_DATADOG_API_KEY=
# OTTO_DATADOG_APP_KEY=

# New Relic
# OTTO_NEWRELIC_API_KEY=
# OTTO_NEWRELIC_ACCOUNT_ID=

# --- Security ---

# HashiCorp Vault
# VAULT_ADDR=
# VAULT_TOKEN=

# Wazuh
# OTTO_WAZUH_URL=
# OTTO_WAZUH_TOKEN=

# --- Project Management ---

# Jira / Confluence
# OTTO_JIRA_URL=
# OTTO_JIRA_EMAIL=
# OTTO_JIRA_TOKEN=

# Linear
# OTTO_LINEAR_TOKEN=

# --- Git ---

# GitLab
# OTTO_GITLAB_URL=
# OTTO_GITLAB_TOKEN=

# Bitbucket
# OTTO_BITBUCKET_USER=
# OTTO_BITBUCKET_TOKEN=

# --- Incident Management ---

# PagerDuty
# OTTO_PAGERDUTY_TOKEN=

# OpsGenie
# OTTO_OPSGENIE_TOKEN=
